{
  "name": "Handle PR Feedback",
  "version": "1.0.0",
  "description": "Invoked when new PR review feedback is detected, parses and delivers to agent",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "You have new code review feedback on your PR. Parse the review comments and respond to each blocking issue (❌) and suggestion (⚠️). Use the review-parser skill to extract structured feedback, then post your response addressing each point. Be collegial and appreciative in your response."
  }
}
